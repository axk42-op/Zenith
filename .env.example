# Discord Bot Token (required)
TOKEN=your_bot_token_here

# Application / Client ID (required)
CLIENT_ID=your_client_id_here

# Primary Guild ID for slash command deployment (required)
GUILD_ID=your_guild_id_here

# Override config.json values (optional)
# WELCOME_CHANNEL=
# LOG_CHANNEL=
# TICKET_CATEGORY=
# TICKET_LOG_CHANNEL=
# APPLICATION_CHANNEL=
# VERIFICATION_ROLE=
# MEMBER_ROLE=
# STAFF_ROLE=
# MODERATOR_ROLE=
# SUGGESTION_CHANNEL=
